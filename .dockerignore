# Version control
.git
.gitignore
.gitattributes

# Python build / runtime caches
__pycache__
*.py[cod]
*$py.class
*.egg-info
.pytest_cache
.hypothesis
.mypy_cache
.ruff_cache
.coverage
coverage.xml
htmlcov

# Local virtualenvs (Dockerfile creates its own via Poetry)
