venv
env

# Local-only config and secrets
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
id_rsa*
credentials*
secrets*

# Tests / docs / examples are not needed at runtime
tests
docs
examples

# Editor / OS cruft
.DS_Store
.idea
.vscode
*.swp
*~

# CI / local tooling state
.github
.claude

# Planning / local notes
plans
*.tmp
